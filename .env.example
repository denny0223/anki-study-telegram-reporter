VOCABULARY_TARGET_COUNT=1600
EXAM_DATE=2026-05-17
REPORT_SLOT=auto
SUPERVISOR_USERNAMES=
TARGET_DECKS=
EXCLUDED_DECKS=

# Local development defaults.
SOURCE=mock
DRY_RUN=true
