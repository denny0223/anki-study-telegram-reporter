# Anki credentials for production AnkiWeb collection fetching.
ANKI_USERNAME=
ANKI_PASSWORD=
ANKI_COLLECTION_OUTPUT_DIR=

# Telegram delivery settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Report behavior.
